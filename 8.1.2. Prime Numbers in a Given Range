start = int(input())
end = int(input())

primes_found = False

for number in range(start, end + 1):
    if number > 1:
        is_prime = True
        for i in range(2, number):
            if number % i == 0:
                is_prime = False
                break
        
        if is_prime:
            print(number)
            primes_found = True

if not primes_found:
    print("No primes")
